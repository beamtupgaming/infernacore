{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Into The Flames Mod Manifest",
  "type": "object",
  "required": ["id", "name", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "entry": {
      "type": "string"
    },
    "gameVersion": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "enabledByDefault": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
